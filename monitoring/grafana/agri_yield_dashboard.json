{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "title": "Agri-Yield MLOps",
  "uid": "agri-yield-mlops",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Predictions per Hour",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "expr": "sum(rate(agri_yield_predictions_total[1h])) by (crop_type)",
        "legendFormat": "{{crop_type}}"
      }]
    },
    {
      "id": 2,
      "title": "Drift Warning Rate (24h)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 6 },
      "targets": [{
        "expr": "sum(increase(agri_yield_drift_warnings_total[24h]))"
      }],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "value": 0, "color": "green" },
            { "value": 1, "color": "yellow" },
            { "value": 10, "color": "red" }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "P95 Prediction Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(agri_yield_prediction_latency_seconds_bucket[5m])) by (le))",
        "legendFormat": "P95 latency"
      }]
    },
    {
      "id": 4,
      "title": "PSI Score by Feature",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [{
        "expr": "agri_yield_psi_score",
        "legendFormat": "{{feature_name}}"
      }],
      "options": {
        "thresholds": {
          "steps": [
            { "value": 0,    "color": "green" },
            { "value": 0.10, "color": "yellow" },
            { "value": 0.20, "color": "red" }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Active Model Version",
      "type": "stat",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 6 },
      "targets": [{
        "expr": "agri_yield_model_version",
        "legendFormat": "Model version"
      }]
    },
    {
      "id": 6,
      "title": "Confidence Interval Width Distribution",
      "type": "histogram",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 6 },
      "targets": [{
        "expr": "agri_yield_confidence_interval_width_bucket",
        "legendFormat": "CI width (kg/ha)"
      }]
    },
    {
      "id": 7,
      "title": "Stale Feature Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "expr": "sum(rate(agri_yield_stale_feature_requests_total[1h])) by (field_id)",
        "legendFormat": "{{field_id}}"
      }]
    },
    {
      "id": 8,
      "title": "Retrain Events",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 6 },
      "targets": [{
        "expr": "increase(agri_yield_retrain_events_total[7d])",
        "legendFormat": "{{trigger_reason}}"
      }]
    }
  ]
}